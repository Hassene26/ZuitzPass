# Copy to .env and fill from the World ID Developer Portal (developer.world.org).
# The portal gives you these three when you enable World ID 4.0 on your app.

# Public (sent to the browser) — safe to expose:
VITE_APP_ID=app_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
VITE_RP_ID=rp_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
VITE_ACTION=zuitzpass-access
# The wallet address you'll later pass to gate.verify() (full 42-char address):
VITE_SIGNAL=0x0000000000000000000000000000000000000000

# SECRET — never commit, never expose to the browser (no VITE_ prefix):
RP_SIGNING_KEY=0xyour_rp_signing_key_from_the_portal
