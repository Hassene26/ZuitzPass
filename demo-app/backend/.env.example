# Copy to .env (loaded via `node --env-file=.env`).
RPC_URL=https://worldchain-sepolia.g.alchemy.com/public
RELAYER_KEY=0xyour_funded_dev_key   # the EOA that owns the contracts (statement owner, tree writer, relayer)
REPO_ROOT=/absolute/path/to/ZuitzPass   # for shelling to nargo/bb + the circuits (used in later slices)
PORT=8787

# World ID v4 (same values as contracts/frontend-idkit/.env — from developer.world.org)
VITE_APP_ID=app_xxxx
VITE_RP_ID=rp_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
RP_SIGNING_KEY=0xyour_rp_signing_key
VITE_ACTION=zuitzpass-access

# Vouch (zkTLS) provider — Phase-1 spike. See VOUCH_SPIKE.md.
# The REAL ticket check is DKIM email verification (no account needed):
VOUCH_ISSUER_DOMAIN=lu.ma      # uploaded email must be DKIM-signed by this domain
VOUCH_SUBJECT_MATCH=           # optional: require this substring in the Subject (e.g. the event name)
VOUCH_EVENT_ID=evt_cannes2026

# TEST-ONLY DNS override so a self-signed sample email verifies without real DNS.
# Easiest: run `node make-test-eml.mjs` — it writes dkimtest.json which the backend AUTO-LOADS
# (no env needed). These env vars are an alternative to that file and take precedence if set.
# Leave UNSET in production — real Luma emails resolve lu.ma's key via DNS.
VOUCH_DKIM_TEST_DOMAIN=
VOUCH_DKIM_TEST_SELECTOR=
VOUCH_DKIM_TEST_PUBKEY=

# Webhook path (alternative zkTLS route, kept for reference) + real SDK guard:
VOUCH_WEBHOOK_SECRET=devsecret
VOUCH_API_KEY=                 # leave empty for the mock/DKIM path; set to enable the real getDataSourceUrl call
VOUCH_DATASOURCE_ID=          # the lu.ma ticket data source id (from the Vouch catalog)
